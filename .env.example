# ============================================
# AgriNet AI — Environment Variables
# Copy this to .env and fill in your values
# ============================================

# ----- Weather (free at openweathermap.org/api) -----
OPENWEATHERMAP_KEY=your_openweathermap_api_key_here

# ----- Geocoding (free at opencagedata.com) -----
OPENCAGE_KEY=your_opencage_api_key_here

# ----- Supabase (free at supabase.com) -----
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ----- LLM Chatbot (free credits at openrouter.ai) -----
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# ----- LibreTranslate (public instance, no key needed) -----
LIBRE_TRANSLATE_URL=https://libretranslate.com
LIBRE_TRANSLATE_KEY=

# ----- App Config -----
APP_SECRET=change_this_to_a_random_secret_string_in_production
ENVIRONMENT=development

# ----- CORS Origins (comma-separated, * for all) -----
CORS_ORIGINS=*
